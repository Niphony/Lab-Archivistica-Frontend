---

<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="text-center mb-14">
      <h2 class="font-display font-bold text-3xl sm:text-4xl text-navy-900 mb-3">Nuestros servicios</h2>
      <div class="w-12 h-1 bg-accent-500 mx-auto rounded-full"></div>
    </div>

    <!-- Cards grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {services.map((service) => (
        <div class="group bg-white border border-gray-200 rounded-xl p-6 hover:border-accent-400 hover:shadow-lg hover:shadow-accent-500/10 transition-all duration-300 flex flex-col">
          <!-- Icon -->
          <div class="text-accent-500 mb-4 transition-transform group-hover:scale-110 duration-300" set:html={service.icon} />

          <!-- Title -->
          <h3 class="font-display font-semibold text-navy-900 text-lg mb-3 leading-tight">{service.title}</h3>

          <!-- Description -->
          <p class="text-gray-500 text-sm leading-relaxed flex-1">{service.description}</p>

          <!-- Link -->
          <!-- <a -->
          <!--   href={service.href} -->
          <!--   class="inline-flex items-center gap-1.5 mt-5 text-accent-500 text-sm font-semibold hover:gap-2.5 transition-all duration-200" -->
          <!-- > -->
          <!--   Ver más -->
          <!--   <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"> -->
          <!--     <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/> -->
          <!--   </svg> -->
          <!-- </a> -->
        </div>
      ))}
    </div>
  </div>
</section>
