---
const navLinks = [
  { label: 'Inicio', href: '/', active: true },
  { label: 'Servicios', href: '#' },
  { label: 'Software', href: '#' },
  { label: 'Equipos', href: '#' },
  { label: 'Investigación', href: '#' },
  { label: 'Contacto', href: '#contacto' },
];
---

<header class="bg-navy-900 border-b border-white/10 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 lg:h-[70px]">

      <!-- Logo left -->
      <a href="/" class="flex items-center gap-3 shrink-0">
      <div class="flex items-center">
  <img
    src="/image.png"
    alt="Universidad Distrital Francisco José de Caldas"
    class="h-12 w-auto object-contain"
  />
</div> 

        <!-- Divider -->
        <div class="w-px h-10 bg-white/20 mx-1 hidden md:block"></div>

        <!-- Lab logo -->
        <div class="hidden md:flex items-center gap-2">
          <div class="w-9 h-9 border-2 border-accent-500 rounded flex items-center justify-center">
            <svg viewBox="0 0 24 24" class="w-5 h-5 text-accent-400" fill="none" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
            </svg>
          </div>
          <div>
            <p class="text-[9px] text-white/50 uppercase tracking-widest leading-none">Laboratorio de</p>
            <p class="text-white font-display font-bold text-sm leading-tight">ARCHIVÍSTICA</p>
            <p class="text-[9px] text-white/50 uppercase tracking-widest leading-none">Y HUMANIDADES DIGITALES</p>
          </div>
        </div>
      </a>

      <!-- Nav links desktop -->
      <nav class="hidden lg:flex items-center gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class={`px-3 py-2 text-sm font-semibold tracking-wide transition-colors duration-150 rounded
              ${link.active
                ? 'text-accent-400 border-b-2 border-accent-400 rounded-none'
                : 'text-white/70 hover:text-white'
              }`}
          >
            {link.label.toUpperCase()}
          </a>
        ))}
      </nav>

      <!-- Mobile menu button -->
      <button
        id="menu-btn"
        class="lg:hidden text-white/70 hover:text-white p-2"
        aria-label="Abrir menú"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-navy-800 border-t border-white/10">
    <nav class="max-w-7xl mx-auto px-4 py-3 flex flex-col gap-1">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`px-3 py-2 text-sm font-semibold tracking-wide rounded transition-colors
            ${link.active ? 'text-accent-400 bg-accent-500/10' : 'text-white/70 hover:text-white hover:bg-white/5'}`}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
