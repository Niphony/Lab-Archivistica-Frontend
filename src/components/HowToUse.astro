---
const steps = [
  {
    number: '01',
    title: 'Solicitud',
    description: 'Diligencia el formulario de reserva o solicitud de servicio.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z" />
    </svg>`,
  },
  {
    number: '02',
    title: 'Validación',
    description: 'El equipo del laboratorio revisa y valida tu solicitud.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>`,
  },
  {
    number: '03',
    title: 'Uso del servicio',
    description: 'Accede al laboratorio y utiliza los recursos asignados.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
    </svg>`,
  },
  {
    number: '04',
    title: 'Seguimiento',
    description: 'Evaluamos el uso para mejorar continuamente nuestros servicios.',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-7 h-7">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
    </svg>`,
  },
];
---

<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-14">
      <h2 class="font-display font-bold text-3xl sm:text-4xl text-navy-900 mb-3">¿Cómo usar el laboratorio?</h2>
      <div class="w-12 h-1 bg-accent-500 mx-auto rounded-full"></div>
    </div>

    <!-- Steps -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-0 relative">

      {steps.map((step, i) => (
        <div class="relative flex flex-col items-center text-center px-6 group">

          <!-- Connector arrow (between steps, desktop only) -->
          {i < steps.length - 1 && (
            <div class="hidden lg:block absolute top-10 left-[calc(50%+44px)] right-0 h-px">
              <div class="w-full flex items-center">
                <div class="flex-1 border-t-2 border-dashed border-accent-400/40"></div>
                <svg class="w-4 h-4 text-accent-400/60 shrink-0 -ml-1" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M8.25 4.5l7.5 7.5-7.5 7.5"/>
                </svg>
              </div>
            </div>
          )}

          <!-- Number + Icon circle -->
          <div class="relative mb-4">
            <div class="w-20 h-20 rounded-full border-2 border-accent-200 bg-accent-50 flex items-center justify-center text-accent-500 group-hover:border-accent-400 group-hover:bg-accent-100 transition-colors duration-300">
              <div set:html={step.icon} />
            </div>
            <span class="absolute -top-1 -right-1 w-7 h-7 bg-accent-500 text-white text-xs font-bold rounded-full flex items-center justify-center font-display">
              {step.number}
            </span>
          </div>

          <!-- Text -->
          <h3 class="font-display font-bold text-navy-900 text-base mb-2">{step.title}</h3>
          <p class="text-gray-500 text-sm leading-relaxed max-w-[180px]">{step.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
