---

<section class="py-16 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

      <!-- Software disponible -->
      <div class="bg-white rounded-2xl border border-gray-200 p-7 shadow-sm">
        <div class="flex items-center justify-between mb-6">
          <h2 class="font-display font-bold text-xl text-navy-900">Software disponible</h2>
          <a href="#" class="inline-flex items-center gap-1 text-accent-500 text-sm font-semibold hover:gap-2 transition-all">
            Ver todos
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </a>
        </div>

        <div class="grid grid-cols-3 gap-3">
          {softwareList.map((sw) => (
            <div class="group bg-navy-900 hover:bg-navy-800 rounded-xl p-4 flex flex-col items-center gap-2 cursor-pointer transition-colors duration-200">
              <div set:html={sw.logo} />
              <span class="text-white/80 text-xs font-semibold text-center group-hover:text-white transition-colors">{sw.name}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Equipos del laboratorio -->
      <div class="bg-white rounded-2xl border border-gray-200 p-7 shadow-sm">
        <div class="flex items-center justify-between mb-6">
          <h2 class="font-display font-bold text-xl text-navy-900">Equipos del laboratorio</h2>
          <a href="/equipos" class="inline-flex items-center gap-1 text-accent-500 text-sm font-semibold hover:gap-2 transition-all">
            Ver inventario
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </a>
        </div>

        <div class="grid grid-cols-2 gap-4">
          {equipment.map((item) => (
            <div class="border border-gray-100 rounded-xl p-5 flex items-start gap-4 hover:border-accent-300 hover:bg-accent-500/5 transition-all duration-200 group">
              <div class="text-accent-500 shrink-0 group-hover:scale-110 transition-transform" set:html={item.icon} />
              <div>
                <p class="font-display font-bold text-3xl text-navy-900 leading-none mb-1">{item.count}</p>
                <p class="text-gray-500 text-xs leading-snug">{item.label}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </div>
</section>
