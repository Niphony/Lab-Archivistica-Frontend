---
import Layout from '../../layouts/Layout.astro';
import { equiposApi } from '../../lib/api';

let equipos = [];
let error = null;
try {
  equipos = await equiposApi.getAll();
} catch (e) {
  error = 'No se pudo cargar la lista de equipos.';
}
---
<Layout title="Equipos">
  <section class="bg-navy-900 border-b border-white/10 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-2">
        <a href="/servicios" class="text-white/40 hover:text-white/70 text-sm transition-colors">Servicios</a>
        <span class="text-white/20">/</span>
        <span class="text-accent-400 text-sm">Equipos</span>
      </div>
      <h1 class="text-4xl font-display font-bold text-white mb-3">Préstamo de Equipos</h1>
      <p class="text-white/60 max-w-xl">Consulta los equipos disponibles y realiza tu solicitud de préstamo directamente desde aquí.</p>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    {error && (
      <div class="bg-red-500/10 border border-red-400/30 rounded-xl p-6 text-center mb-8">
        <p class="text-red-300">{error}</p>
      </div>
    )}

    <!-- Filtros -->
    <div class="flex flex-wrap gap-3 mb-8" id="filters">
      <button class="filter-btn active px-4 py-1.5 text-sm rounded-full border border-accent-400 text-accent-400 font-semibold" data-filter="all">Todos</button>
      <button class="filter-btn px-4 py-1.5 text-sm rounded-full border border-white/20 text-white/60 hover:border-white/40 hover:text-white font-semibold" data-filter="disponible">Disponibles</button>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" id="equipos-grid">
      {equipos.map((eq) => (
        <div class="bg-navy-800 border border-white/10 rounded-2xl overflow-hidden hover:border-accent-400/30 transition-all duration-300 equipment-card" data-available={eq.available}>
          <div class="bg-navy-700/50 h-40 flex items-center justify-center">
            {eq.imageUrl
              ? <img src={eq.imageUrl} alt={eq.name} class="h-full w-full object-cover" />
              : (
                <svg class="w-16 h-16 text-white/20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25A2.25 2.25 0 015.25 3h13.5A2.25 2.25 0 0121 5.25z"/>
                </svg>
              )
            }
          </div>
          <div class="p-5">
            <div class="flex items-start justify-between mb-2">
              <h3 class="font-display font-bold text-white">{eq.name}</h3>
              <span class={`text-xs px-2 py-0.5 rounded-full font-semibold shrink-0 ml-2 ${eq.available ? 'bg-green-500/15 text-green-400 border border-green-400/20' : 'bg-red-500/15 text-red-400 border border-red-400/20'}`}>
                {eq.available ? 'Disponible' : 'No disponible'}
              </span>
            </div>
            <p class="text-white/50 text-sm mb-4 line-clamp-2">{eq.description}</p>
            {eq.available && (
              <a href={`/equipos/${eq.id}`} class="inline-flex items-center gap-2 bg-accent-500 hover:bg-accent-600 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors w-full justify-center">
                Solicitar préstamo
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
  </section>
</Layout>

<script>
  document.querySelectorAll('.filter-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active', 'border-accent-400', 'text-accent-400'));
      btn.classList.add('active', 'border-accent-400', 'text-accent-400');
      const filter = btn.dataset.filter;
      document.querySelectorAll('.equipment-card').forEach(card => {
        if (filter === 'all') { card.style.display = ''; }
        else { card.style.display = card.dataset.available === 'true' ? '' : 'none'; }
      });
    });
  });
</script>
