---
import Layout from '../../../layouts/Layout.astro';
---
<Layout title="Salas">
  <section class="bg-navy-900 border-b border-white/10 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-2">
        <a href="/servicios" class="text-white/40 hover:text-white/70 text-sm">Servicios</a>
        <span class="text-white/20">/</span>
        <span class="text-accent-400 text-sm">Salas</span>
      </div>
      <h1 class="text-4xl font-display font-bold text-white mb-3">Reserva de Salas</h1>
      <p class="text-white/60 max-w-xl">Espacios equipados para trabajo individual o grupal, digitalización e investigación.</p>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

       <a href="https://forms.cloud.microsoft/pages/responsepage.aspx?id=74gT1bBqY0OflNVmRKRZcCYdtW4rSUhOkGItZSP0FSVUMkxQQTdaVUxZMlg4RTIyMFhJMTNJUU5RRC4u&route=shorturl" class="group bg-navy-800 border border-white/10 rounded-2xl p-8 hover:border-accent-400/50 hover:bg-navy-700 transition-all duration-300">
        <div class="w-14 h-14 bg-accent-500/10 border border-accent-500/20 rounded-xl flex items-center justify-center mb-6 group-hover:bg-accent-500/20 transition-colors">
          <svg class="w-7 h-7 text-accent-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21"/>
          </svg>
        </div>
        <h2 class="text-xl font-display font-bold text-white mb-3 group-hover:text-accent-300 transition-colors">Formulario de Reserva</h2>
        <p class="text-white/60 text-sm leading-relaxed mb-4">
          Reserva por medio de formularios las salas especializadas que necesites para el trabajo colaborativo.
        </p>
        <span class="text-accent-400 text-sm font-semibold flex items-center gap-1">
          Formulario
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </span>
       </a>

         <a href="mailto:labarchivistica@udistrital.edu.co" class="group bg-navy-800 border border-white/10 rounded-2xl p-8 hover:border-accent-400/50 hover:bg-navy-700 transition-all duration-300">
        <div class="w-14 h-14 bg-accent-500/10 border border-accent-500/20 rounded-xl flex items-center justify-center mb-6 group-hover:bg-accent-500/20 transition-colors">
          <svg class="w-7 h-7 text-accent-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21"/>
          </svg>
        </div>
        <h2 class="text-xl font-display font-bold text-white mb-3 group-hover:text-accent-300 transition-colors">Para otros calendarios de reserva.</h2>
        <p class="text-white/60 text-sm leading-relaxed mb-4">
          Otras opciones de reserva ofrecidas por los laboratorios de archivística y humanidades digitales.
        </p>
        <span class="text-accent-400 text-sm font-semibold flex items-center gap-1">
          Preguntar Salas Disponibles
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </span>
      </a>

      </div>
  </section>
</Layout>
