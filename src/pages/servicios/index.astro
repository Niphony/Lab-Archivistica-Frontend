---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Servicios">
  <!-- Hero -->
  <section class="bg-navy-900 border-b border-white/10 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-block px-3 py-1 text-xs font-bold tracking-widest text-accent-400 border border-accent-400/30 rounded-full mb-4 uppercase">
        Nuestros servicios
      </span>
      <h1 class="text-4xl lg:text-5xl font-display font-bold text-white mb-4">
 Servicios del Laboratorio
      </h1>
      <p class="text-white/60 max-w-2xl mx-auto text-lg">
        El Laboratorio de Archivística y Humanidades Digitales ofrece recursos y espacios
        para la comunidad universitaria. Conoce cómo acceder a cada servicio.
      </p>
    </div>
  </section>

  <!-- Cobertura de servicios -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

      <!-- Préstamo de Equipos -->
      <div class="bg-navy-800 border border-white/10 rounded-2xl p-7">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-11 h-11 bg-accent-500/10 border border-accent-500/20 rounded-xl flex items-center justify-center">
            <svg class="w-5 h-5 text-accent-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0H3" />
            </svg>
          </div>
          <h2 class="text-lg font-display font-bold text-white">Préstamo de Equipos</h2>
        </div>
        <ul class="space-y-2.5 text-sm text-white/60">
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-accent-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4.5 12.75l6 6 9-13.5"/></svg>
            Computadores de escritorio y portátiles
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-accent-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4.5 12.75l6 6 9-13.5"/></svg>
            Escáner planetario y cámaras digitales
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-accent-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4.5 12.75l6 6 9-13.5"/></svg>
            Tabletas digitalizadoras
          </li>
        </ul>
        <div class="mt-5 pt-5 border-t border-white/10">
          <div class="flex items-center justify-between text-xs text-white/40 mb-3">
            <span>Préstamo: hasta 7 días</span>
            <span>Comunidad UD</span>
          </div>
          <a href="/equipos" class="inline-flex items-center justify-center gap-1.5 w-full bg-accent-500 hover:bg-accent-600 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors">
            Ver inventario
          </a>
        </div>
      </div>

      <!-- Reserva de Salas -->
      <div class="bg-navy-800 border border-white/10 rounded-2xl p-7">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-11 h-11 bg-accent-500/10 border border-accent-500/20 rounded-xl flex items-center justify-center">
            <svg class="w-5 h-5 text-accent-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21" />
            </svg>
          </div>
          <h2 class="text-lg font-display font-bold text-white">Reserva de Salas</h2>
        </div>
        <ul class="space-y-2.5 text-sm text-white/60">
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-accent-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4.5 12.75l6 6 9-13.5"/></svg>
            Sala de digitalización (6 personas)
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-accent-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4.5 12.75l6 6 9-13.5"/></svg>
            Sala de trabajo colaborativo (12 personas)
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-accent-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4.5 12.75l6 6 9-13.5"/></svg>
            Cubículos de estudio individual/grupal
          </li>
        </ul>
        <div class="mt-5 pt-5 border-t border-white/10">
          <div class="flex items-center justify-between text-xs text-white/40 mb-3">
            <span>Reserva: formulario externo</span>
            <span>Estudiantes y docentes</span>
          </div>
          <a href="/servicios/salas" class="inline-flex items-center justify-center gap-1.5 w-full bg-accent-500 hover:bg-accent-600 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors">
            Ver salas
          </a>
        </div>
      </div>

      <!-- Software -->
      <div class="bg-navy-800 border border-white/10 rounded-2xl p-7">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-11 h-11 bg-accent-500/10 border border-accent-500/20 rounded-xl flex items-center justify-center">
            <svg class="w-5 h-5 text-accent-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0021 18V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v12a2.25 2.25 0 002.25 2.25z" />
            </svg>
          </div>
          <h2 class="text-lg font-display font-bold text-white">Software Especializado</h2>
        </div>
        <ul class="space-y-2.5 text-sm text-white/60">
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-accent-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4.5 12.75l6 6 9-13.5"/></svg>
            Repositorios digitales (DSpace, AtoM)
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-accent-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4.5 12.75l6 6 9-13.5"/></svg>
            Preservación digital (Archivematica)
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-accent-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4.5 12.75l6 6 9-13.5"/></svg>
            Gestión documental (Orfeo, Apache Tika)
          </li>
        </ul>
        <div class="mt-5 pt-5 border-t border-white/10">
          <div class="flex items-center justify-between text-xs text-white/40 mb-3">
            <span>Acceso: estaciones del lab</span>
            <span>Uso académico</span>
          </div>
          <a href="/software" class="inline-flex items-center justify-center gap-1.5 w-full bg-accent-500 hover:bg-accent-600 text-white text-sm font-semibold px-4 py-2 rounded-lg transition-colors">
            Ver catálogo
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- Información práctica -->
  <section class="bg-navy-900/50 border-y border-white/5 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">

        <div class="bg-navy-800 border border-white/10 rounded-xl p-6 text-center">
          <div class="w-10 h-10 bg-accent-500/10 rounded-lg flex items-center justify-center mx-auto mb-3">
            <svg class="w-5 h-5 text-accent-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-white font-semibold text-sm mb-1">Horario</h3>
          <p class="text-white/50 text-xs">Lun – Vie<br/>8:00 a.m. – 4:00 p.m.</p>
        </div>

        <div class="bg-navy-800 border border-white/10 rounded-xl p-6 text-center">
          <div class="w-10 h-10 bg-accent-500/10 rounded-lg flex items-center justify-center mx-auto mb-3">
            <svg class="w-5 h-5 text-accent-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
            </svg>
          </div>
          <h3 class="text-white font-semibold text-sm mb-1">Dirigido a</h3>
          <p class="text-white/50 text-xs">Estudiantes, docentes e investigadores de la Universidad Distrital</p>
        </div>

        <div class="bg-navy-800 border border-white/10 rounded-xl p-6 text-center">
          <div class="w-10 h-10 bg-accent-500/10 rounded-lg flex items-center justify-center mx-auto mb-3">
            <svg class="w-5 h-5 text-accent-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-white font-semibold text-sm mb-1">Requisitos</h3>
          <p class="text-white/50 text-xs">Carnet UD vigente y formulario de solicitud diligenciado</p>
        </div>

        <div class="bg-navy-800 border border-white/10 rounded-xl p-6 text-center">
          <div class="w-10 h-10 bg-accent-500/10 rounded-lg flex items-center justify-center mx-auto mb-3">
            <svg class="w-5 h-5 text-accent-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182" />
            </svg>
          </div>
          <h3 class="text-white font-semibold text-sm mb-1">Ubicación</h3>
          <p class="text-white/50 text-xs">Bloque 3, Piso 4, Sala 407<br/>Bosa Porvenir</p>
        </div>

      </div>
    </div>
  </section>

  <!-- Proceso -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-12">
      <h2 class="text-2xl lg:text-3xl font-display font-bold text-white mb-3">¿Cómo solicitar un préstamo?</h2>
      <p class="text-white/50 max-w-lg mx-auto">El proceso es sencillo y está diseñado para que accedas rápido a los recursos que necesitas.</p>
    </div>

    <div class="relative">
      <!-- Línea conectora desktop -->
      <div class="hidden lg:block absolute top-12 left-[12.5%] right-[12.5%] h-0.5 bg-gradient-to-r from-accent-400/20 via-accent-400/40 to-accent-400/20"></div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-0">
        {[
          { step: '01', title: 'Selecciona', desc: 'Elige el equipo o sala que necesitas en el catálogo.', color: 'bg-accent-500' },
          { step: '02', title: 'Solicita', desc: 'Diligencia el formulario de solicitud con tus datos.', color: 'bg-accent-500' },
          { step: '03', title: 'Confirmación', desc: 'Recibirás la confirmación por correo electrónico.', color: 'bg-accent-500' },
          { step: '04', title: 'Entrega', desc: 'Firma el control de préstamo y recibe los recursos asignados.', color: 'bg-accent-500' },
        ].map(({ step, title, desc, color }) => (
          <div class="flex flex-col items-center text-center relative px-4">
            <div class={`w-11 h-11 ${color} rounded-full flex items-center justify-center text-white font-bold font-display text-sm mb-4 relative z-10 shadow-lg shadow-accent-500/25`}>
              {step}
            </div>
            <h3 class="text-white font-semibold mb-1.5">{title}</h3>
            <p class="text-white/50 text-sm max-w-[180px]">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Políticas rápidas -->
  <section class="bg-navy-900/30 border-t border-white/5 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4 bg-navy-800 border border-white/10 rounded-xl p-6">
        <div class="flex items-center gap-3">
          <svg class="w-5 h-5 text-accent-400 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 11-18 0 9 9 0 0118 0zm-9 3.75h.008v.008H12v-.008z" />
          </svg>
          <p class="text-white/70 text-sm">
            <span class="text-white font-semibold">Política de préstamos:</span> Los recursos deben devolverse en las mismas condiciones. El incumplimiento puede generar restricciones de acceso futuro.
          </p>
        </div>
        <a href="mailto:labarchivistica@udistrital.edu.co" class="shrink-0 text-accent-400 text-sm font-semibold hover:text-accent-300 transition-colors whitespace-nowrap">
          ¿Dudas? Escríbenos
        </a>
      </div>
    </div>
  </section>
</Layout>
