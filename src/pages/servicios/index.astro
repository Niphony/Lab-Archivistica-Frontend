---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Servicios">
  <!-- Hero de sección -->
  <section class="bg-navy-900 border-b border-white/10 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="inline-block px-3 py-1 text-xs font-bold tracking-widest text-accent-400 border border-accent-400/30 rounded-full mb-4 uppercase">
        Nuestros servicios
      </span>
      <h1 class="text-4xl lg:text-5xl font-display font-bold text-white mb-4">
        ¿Qué ofrecemos?
      </h1>
      <p class="text-white/60 max-w-2xl mx-auto text-lg">
        El Laboratorio de Archivística y Humanidades Digitales pone a tu disposición
        equipos, salas y software especializado para la investigación y el aprendizaje.
      </p>
    </div>
  </section>

  <!-- Cards de servicios -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Equipos -->
      <a href="/equipos" class="group bg-navy-800 border border-white/10 rounded-2xl p-8 hover:border-accent-400/50 hover:bg-navy-700 transition-all duration-300">
        <div class="w-14 h-14 bg-accent-500/10 border border-accent-500/20 rounded-xl flex items-center justify-center mb-6 group-hover:bg-accent-500/20 transition-colors">
          <svg class="w-7 h-7 text-accent-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25A2.25 2.25 0 015.25 3h13.5A2.25 2.25 0 0121 5.25z"/>
          </svg>
        </div>
        <h2 class="text-xl font-display font-bold text-white mb-3 group-hover:text-accent-300 transition-colors">Préstamo de Equipos</h2>
        <p class="text-white/60 text-sm leading-relaxed mb-4">
          Accede a computadores, escáneres, digitalizadores y equipos especializados para tus proyectos académicos e investigativos.
        </p>
        <span class="text-accent-400 text-sm font-semibold flex items-center gap-1">
          Ver equipos disponibles
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </span>
      </a>

      <!-- Salas -->
      <a href="/servicios/salas" class="group bg-navy-800 border border-white/10 rounded-2xl p-8 hover:border-accent-400/50 hover:bg-navy-700 transition-all duration-300">
        <div class="w-14 h-14 bg-accent-500/10 border border-accent-500/20 rounded-xl flex items-center justify-center mb-6 group-hover:bg-accent-500/20 transition-colors">
          <svg class="w-7 h-7 text-accent-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21"/>
          </svg>
        </div>
        <h2 class="text-xl font-display font-bold text-white mb-3 group-hover:text-accent-300 transition-colors">Reserva de Salas</h2>
        <p class="text-white/60 text-sm leading-relaxed mb-4">
          Reserva espacios de trabajo colaborativo, salas de digitalización y cubículos de estudio para tu grupo de investigación.
        </p>
        <span class="text-accent-400 text-sm font-semibold flex items-center gap-1">
          Ver salas disponibles
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </span>
      </a>

      <!-- Software -->
      <a href="/software" class="group bg-navy-800 border border-white/10 rounded-2xl p-8 hover:border-accent-400/50 hover:bg-navy-700 transition-all duration-300">
        <div class="w-14 h-14 bg-accent-500/10 border border-accent-500/20 rounded-xl flex items-center justify-center mb-6 group-hover:bg-accent-500/20 transition-colors">
          <svg class="w-7 h-7 text-accent-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0021 18V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v12a2.25 2.25 0 002.25 2.25z"/>
          </svg>
        </div>
        <h2 class="text-xl font-display font-bold text-white mb-3 group-hover:text-accent-300 transition-colors">Catálogo de Software</h2>
        <p class="text-white/60 text-sm leading-relaxed mb-4">
          Consulta el software especializado disponible: herramientas de digitalización, gestión documental, análisis de datos y humanidades digitales.
        </p>
        <span class="text-accent-400 text-sm font-semibold flex items-center gap-1">
          Ver software
          <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        </span>
      </a>
    </div>
  </section>

  <!-- Proceso de préstamo -->
  <section class="bg-navy-900/50 border-t border-white/5 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-display font-bold text-white mb-10 text-center">¿Cómo solicitar un préstamo?</h2>
      <div class="grid grid-cols-1 sm:grid-cols-4 gap-6">
        {[
          { step: '01', title: 'Selecciona el recurso', desc: 'Navega el catálogo de equipos o salas y elige el que necesitas.' },
          { step: '02', title: 'Completa el formulario', desc: 'Completa el formulario con los datos solicitados.' },
          { step: '03', title: 'Confirmación', desc: 'Recibirás una confirmación mediante correo electronico.' },
          { step: '04', title: 'Entrega', desc: 'Se da la entrega de los recursos asignados y firma control para el prestamo de la sala.' },
        ].map(({ step, title, desc }) => (
          <div class="text-center">
            <div class="w-12 h-12 bg-accent-500 rounded-full flex items-center justify-center mx-auto mb-4 text-white font-bold font-display text-sm">{step}</div>
            <h3 class="text-white font-semibold mb-2">{title}</h3>
            <p class="text-white/50 text-sm">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</Layout>
